<div class="content-h1-tienda">
    <h1 class="h1-tienda text-2xl">{{tittle}} </h1>
    <img src="/mando.png" alt="icono de mando" class="icon-mando" draggable="false">
</div>
{{#if hasPrevPage}}
    <a href="?page={{prevPage}}">Anterior</a>
{{/if}}

{{#if hasNextPage}}
    <a href="?page={{nextPage}}">Siguiente</a>
{{/if}}
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4" id="card-productos-io">

    {{#each games}}
    <div class="card bg-base-100" data-id="{{_id}}">
        <div class="card-body">
            <ul>
                <li>
                    <img src="{{thumbnails}}" alt="{{title}}" class="object-cover imgs-cards" draggable="false">
                    <h2 class="text-2xl">{{title}}</h2>
                    <h3><strong>Categoría:</strong> {{category}}</h3>

                    <h3><strong>Precio:</strong> ${{price}}</h3>
                </li>
                <div class="card-actios justify-end">
                    <a class="btn btn-info" href="/products/{{_id}}">Ver detalle</a>
                    <button class="btn btn-info btn-agregar" data-id="{{_id}}">Agregar al carrito</button>
                </div>
            </ul>
        </div>
    </div>
    {{/each}}

</div>
<script src="/js/agregar.js"></script>
<script src="/js/live.js"></script>